---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
---

<header class="site-header">
	<div class="site-wrapper">
		<a href="/" class="site-title"><span class="prompt">~$</span> {SITE_TITLE}</a>
		<nav class="site-nav">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/posts">Posts</HeaderLink>
			<HeaderLink href="/writeups">Writeups</HeaderLink>
			<HeaderLink href="/talks">Talks</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
			<ThemeToggle />
		</nav>
	</div>
</header>
<style>
	.site-header {
		padding: 1.5rem 0 1rem;
		border-bottom: 1px solid var(--border);
		margin-bottom: 2rem;
	}
	.site-wrapper {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		flex-wrap: wrap;
		gap: 0.75rem;
	}
	.site-title {
		font-family: var(--font-mono);
		font-size: 1.05rem;
		font-weight: 500;
		color: var(--text);
		text-decoration: none;
	}
	.site-title:visited { color: var(--text); }
	.site-title:hover { color: var(--accent); }
	.prompt { color: var(--text-tertiary); }
	.site-nav {
		display: flex;
		gap: 1.25rem;
		align-items: center;
	}
	@media (max-width: 640px) {
		.site-wrapper {
			flex-direction: column;
			gap: 0.5rem;
		}
	}
</style>
