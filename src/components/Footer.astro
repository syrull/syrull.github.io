---
const today = new Date();
---

<footer class="site-footer">
	<div class="site-wrapper">
		<span>&copy; {today.getFullYear()} Dimitar Ganev</span>
		<div class="footer-links">
			<a href="/rss.xml">RSS</a>
			<a href="https://github.com/syrull" target="_blank">GitHub</a>
			<a href="https://www.linkedin.com/in/dimitar-ganev-syl-/" target="_blank">LinkedIn</a>
		</div>
	</div>
</footer>
<style>
	.site-footer {
		margin-top: 3rem;
		padding: 1.5rem 0;
		border-top: 1px solid var(--border);
		font-size: 0.82rem;
		color: var(--text-tertiary);
	}
	.site-wrapper {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.footer-links {
		display: flex;
		gap: 1rem;
	}
	.footer-links a {
		color: var(--text-tertiary);
		text-decoration: none;
	}
	.footer-links a:visited { color: var(--text-tertiary); }
	.footer-links a:hover { color: var(--text); }
</style>
