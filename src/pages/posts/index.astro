---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('posts')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const postsByYear = new Map<number, typeof posts>();
for (const post of posts) {
	const year = post.data.pubDate.getFullYear();
	if (!postsByYear.has(year)) postsByYear.set(year, []);
	postsByYear.get(year)!.push(post);
}
const years = [...postsByYear.keys()].sort((a, b) => b - a);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Posts | ${SITE_TITLE}`} description="All blog posts" />
	</head>
	<body>
		<Header />
		<main class="site-wrapper">
			<div class="page-header"><h1>All posts</h1></div>
			{years.map(year => (
				<section class="year-section">
					<h2 class="year-label">{year}</h2>
					<ul class="post-list">
						{postsByYear.get(year)!.map(post => (
							<li class="post-item">
								<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
								<div>
									<a href={`/posts/${post.id}/`} class="post-link">{post.data.title}</a>
									{post.data.description && <p class="post-desc">{post.data.description}</p>}
									{post.data.tags && post.data.tags.length > 0 && (
										<div class="post-tags">{post.data.tags.map(t => <span class="post-tag">{t}</span>)}</div>
									)}
								</div>
							</li>
						))}
					</ul>
				</section>
			))}
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-header { margin-bottom: 1.5rem; }
	.page-header h1 { font-size: 1.5rem; margin: 0; }
	.year-section { margin-bottom: 1.5rem; }
	.year-label { font-family: var(--font-mono); font-size: 0.85rem; color: var(--text-tertiary); font-weight: 500; margin: 0 0 0.5rem 0; }
	.post-list { list-style: none; }
	.post-item { padding: 0.6rem 0; display: grid; grid-template-columns: 7rem 1fr; gap: 0.75rem; align-items: baseline; }
	.post-item + .post-item { border-top: 1px solid var(--border); }
	.post-date { font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-tertiary); white-space: nowrap; }
	.post-link { font-weight: 500; font-size: 0.95rem; text-decoration: none; line-height: 1.4; }
	.post-link:hover { text-decoration: underline; text-decoration-color: currentColor; }
	.post-desc { font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.2rem; line-height: 1.5; }
	.post-tags { display: inline-flex; gap: 0.35rem; margin-top: 0.25rem; flex-wrap: wrap; }
	.post-tag { font-family: var(--font-mono); font-size: 0.7rem; color: var(--tag-text); background: var(--tag-bg); padding: 0.1em 0.5em; border-radius: 3px; }
	@media (max-width: 640px) { .post-item { grid-template-columns: 1fr; } }
</style>
