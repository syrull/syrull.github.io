---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const talks = (await getCollection('talks')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Talks | ${SITE_TITLE}`} description="Conference talks and presentations" />
		<style>
			main {
				width: 960px;
			}
			.page-title {
				margin: 2rem 0 0.5rem 0;
				font-size: 2rem;
			}
			.page-description {
				color: rgb(var(--text-secondary));
				margin: 0 0 2rem 0;
			}
			ul {
				display: flex;
				flex-wrap: wrap;
				gap: 2rem;
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				width: calc(50% - 1rem);
			}
			ul li * {
				text-decoration: none;
				transition: 0.2s ease;
			}
			ul li:first-child {
				width: 100%;
				margin-bottom: 1rem;
				text-align: center;
			}
			ul li:first-child .thumbnail img {
				width: 100%;
			}
			ul li:first-child .title {
				font-size: 2.369rem;
			}
			ul li a {
				display: block;
			}
			.thumbnail {
				position: relative;
				margin-bottom: 0.5rem;
				border-radius: 12px;
				overflow: hidden;
			}
			.thumbnail img {
				width: 100%;
				aspect-ratio: 16/9;
				object-fit: cover;
				display: block;
			}
			.play-overlay {
				position: absolute;
				inset: 0;
				display: flex;
				align-items: center;
				justify-content: center;
				background: rgba(0, 0, 0, 0.2);
				opacity: 0;
				transition: opacity 0.2s ease;
			}
			.play-overlay svg {
				width: 64px;
				height: 64px;
				fill: white;
				filter: drop-shadow(0 2px 4px rgba(0, 0, 0, 0.3));
			}
			ul li a:hover .play-overlay {
				opacity: 1;
			}
			.title {
				margin: 0;
				color: rgb(var(--text-primary));
				line-height: 1;
			}
			.event {
				margin: 0.25rem 0 0 0;
				color: var(--accent);
				font-size: 0.95rem;
				font-weight: 500;
			}
			.date {
				margin: 0;
				color: rgb(var(--text-secondary));
			}
			ul li a:hover h4,
			ul li a:hover .date {
				color: rgb(var(--accent));
			}
			ul a:hover .thumbnail img {
				box-shadow: var(--box-shadow);
			}
			@media (max-width: 720px) {
				ul {
					gap: 0.5em;
				}
				ul li {
					width: 100%;
					text-align: center;
				}
				ul li:first-child {
					margin-bottom: 0;
				}
				ul li:first-child .title {
					font-size: 1.563em;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title">Talks</h1>
			<p class="page-description">Conference talks and presentations.</p>
			<section>
				<ul>
					{
						talks.map((talk) => (
							<li>
								<a href={`/talks/${talk.id}/`}>
									{talk.data.youtubeId && (
										<div class="thumbnail">
											<img
												src={`https://img.youtube.com/vi/${talk.data.youtubeId}/maxresdefault.jpg`}
												alt={talk.data.title}
												width="960"
												height="540"
												loading="lazy"
											/>
											<div class="play-overlay">
												<svg viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
											</div>
										</div>
									)}
									<h4 class="title">{talk.data.title}</h4>
									<p class="event">{talk.data.event}</p>
									<p class="date">
										<FormattedDate date={talk.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>
