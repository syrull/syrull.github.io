---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const talks = (await getCollection('talks')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const byYear = new Map<number, typeof talks>();
for (const t of talks) {
	const year = t.data.pubDate.getFullYear();
	if (!byYear.has(year)) byYear.set(year, []);
	byYear.get(year)!.push(t);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Talks | ${SITE_TITLE}`} description="Conference talks and presentations" />
	</head>
	<body>
		<Header />
		<main class="site-wrapper">
			<div class="page-header"><h1>Talks</h1></div>
			{years.map(year => (
				<section class="year-section">
					<h2 class="year-label">{year}</h2>
					<ul class="post-list">
						{byYear.get(year)!.map(talk => (
							<li class="post-item">
								<span class="post-date"><FormattedDate date={talk.data.pubDate} /></span>
								<div>
									<a href={`/talks/${talk.id}/`} class="post-link">{talk.data.title}</a>
									<p class="post-desc">{talk.data.event}{talk.data.description && ` — ${talk.data.description}`}</p>
								</div>
							</li>
						))}
					</ul>
				</section>
			))}
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-header { margin-bottom: 1.5rem; }
	.page-header h1 { font-size: 1.5rem; margin: 0; }
	.year-section { margin-bottom: 1.5rem; }
	.year-label { font-family: var(--font-mono); font-size: 0.85rem; color: var(--text-tertiary); font-weight: 500; margin: 0 0 0.5rem 0; }
	.post-list { list-style: none; }
	.post-item { padding: 0.6rem 0; display: grid; grid-template-columns: 7rem 1fr; gap: 0.75rem; align-items: baseline; }
	.post-item + .post-item { border-top: 1px solid var(--border); }
	.post-date { font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-tertiary); white-space: nowrap; }
	.post-link { font-weight: 500; font-size: 0.95rem; text-decoration: none; line-height: 1.4; }
	.post-link:hover { text-decoration: underline; text-decoration-color: currentColor; }
	.post-desc { font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.2rem; line-height: 1.5; }
	@media (max-width: 640px) { .post-item { grid-template-columns: 1fr; } }
</style>
