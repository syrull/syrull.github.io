---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('posts')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
).slice(0, 6);

const writeups = (await getCollection('writeups')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
).slice(0, 5);

const talks = (await getCollection('talks')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="site-wrapper">

			<section class="intro">
				<h1>Heya, I'm Dimitar</h1>
				<div class="intro-links">
					<a href="https://github.com/syrull" target="_blank">
						<svg viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
						GitHub
					</a>
					<a href="https://www.linkedin.com/in/dimitar-ganev-syl-/" target="_blank">
						<svg viewBox="0 0 16 16" fill="currentColor"><path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.567-.878 1.228-.878.866 0 1.213.66 1.213 1.628v3.993h2.401V9.25c0-2.213-1.181-3.242-2.756-3.242-1.292 0-1.86.722-2.17 1.509h.016V6.169h-2.4c.03.678 0 7.225 2.4 7.225z"/></svg>
						LinkedIn
					</a>
					<a href="/rss.xml">RSS</a>
				</div>
			</section>

			<section class="section">
				<div class="section-head">
					<h2>Recent posts</h2>
					<a href="/posts/">all posts &rarr;</a>
				</div>
				<ul class="post-list">
					{posts.map((post) => (
						<li class="post-item">
							<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
							<div>
								<a href={`/posts/${post.id}/`} class="post-link">{post.data.title}</a>
								{post.data.description && <p class="post-desc">{post.data.description}</p>}
							</div>
						</li>
					))}
				</ul>
			</section>

			<section class="section">
				<div class="section-head">
					<h2>CTF writeups</h2>
					<a href="/writeups/">all writeups &rarr;</a>
				</div>
				<ul class="post-list">
					{writeups.map((writeup) => (
						<li class="post-item">
							<span class="post-date"><FormattedDate date={writeup.data.pubDate} /></span>
							<div>
								<a href={`/writeups/${writeup.id}/`} class="post-link">{writeup.data.title}</a>
								{writeup.data.tags && writeup.data.tags.length > 0 && (
									<div class="post-tags">
										{writeup.data.tags.map(tag => <span class="post-tag">{tag}</span>)}
									</div>
								)}
							</div>
						</li>
					))}
				</ul>
			</section>

			<section class="section">
				<div class="section-head">
					<h2>Talks</h2>
					<a href="/talks/">all talks &rarr;</a>
				</div>
				<ul class="post-list">
					{talks.map((talk) => (
						<li class="post-item">
							<span class="post-date"><FormattedDate date={talk.data.pubDate} /></span>
							<div>
								<a href={`/talks/${talk.id}/`} class="post-link">{talk.data.title}</a>
								<p class="post-desc">{talk.data.event}{talk.data.description && ` — ${talk.data.description}`}</p>
							</div>
						</li>
					))}
				</ul>
			</section>

		</main>
		<Footer />
	</body>
</html>

<style>
	.intro { margin-bottom: 2.5rem; }
	.intro h1 { font-size: 1.8rem; font-weight: 700; margin-bottom: 0.75rem; }
	.intro p { color: var(--text-secondary); font-size: 0.95rem; line-height: 1.65; margin-bottom: 0.4rem; }
	.intro-links { display: flex; gap: 1rem; margin-top: 1rem; }
	.intro-links a { font-size: 0.85rem; color: var(--text-secondary); text-decoration: none; display: inline-flex; align-items: center; gap: 0.3rem; }
	.intro-links a:visited { color: var(--text-secondary); }
	.intro-links a:hover { color: var(--link); }
	.intro-links svg { width: 15px; height: 15px; }
	.section { margin-bottom: 2.5rem; }
	.section-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.75rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--border); }
	.section-head h2 { font-size: 1.15rem; font-weight: 700; margin: 0; }
	.section-head a { font-size: 0.82rem; color: var(--text-tertiary); text-decoration: none; font-weight: 500; }
	.section-head a:visited { color: var(--text-tertiary); }
	.section-head a:hover { color: var(--link); }
	.post-list { list-style: none; }
	.post-item { padding: 0.6rem 0; display: grid; grid-template-columns: 7.5rem 1fr; gap: 0.75rem; align-items: baseline; }
	.post-item + .post-item { border-top: 1px solid var(--border); }
	.post-date { font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-tertiary); white-space: nowrap; }
	.post-link { font-weight: 500; font-size: 0.95rem; text-decoration: none; line-height: 1.4; }
	.post-link:hover { text-decoration: underline; text-decoration-color: currentColor; }
	.post-desc { font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.2rem; line-height: 1.5; }
	.post-tags { display: inline-flex; gap: 0.35rem; margin-top: 0.25rem; flex-wrap: wrap; }
	.post-tag { font-family: var(--font-mono); font-size: 0.7rem; color: var(--tag-text); background: var(--tag-bg); padding: 0.1em 0.5em; border-radius: 3px; }
	@media (max-width: 640px) {
		.post-item { grid-template-columns: 1fr; gap: 0.15rem; }
		.intro h1 { font-size: 1.5rem; }
	}
</style>
