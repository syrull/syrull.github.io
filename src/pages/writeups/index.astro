---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const writeups = (await getCollection('writeups')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const byYear = new Map<number, typeof writeups>();
for (const w of writeups) {
	const year = w.data.pubDate.getFullYear();
	if (!byYear.has(year)) byYear.set(year, []);
	byYear.get(year)!.push(w);
}
const years = [...byYear.keys()].sort((a, b) => b - a);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Writeups | ${SITE_TITLE}`} description="CTF writeups" />
	</head>
	<body>
		<Header />
		<main class="site-wrapper">
			<div class="page-header"><h1>CTF writeups</h1></div>
			{years.map(year => (
				<section class="year-section">
					<h2 class="year-label">{year}</h2>
					<ul class="post-list">
						{byYear.get(year)!.map(w => (
							<li class="post-item">
								<span class="post-date"><FormattedDate date={w.data.pubDate} /></span>
								<div>
									<a href={`/writeups/${w.id}/`} class="post-link">{w.data.title}</a>
									{w.data.tags && w.data.tags.length > 0 && (
										<div class="post-tags">{w.data.tags.map(t => <span class="post-tag">{t}</span>)}</div>
									)}
								</div>
							</li>
						))}
					</ul>
				</section>
			))}
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-header { margin-bottom: 1.5rem; }
	.page-header h1 { font-size: 1.5rem; margin: 0; }
	.year-section { margin-bottom: 1.5rem; }
	.year-label { font-family: var(--font-mono); font-size: 0.85rem; color: var(--text-tertiary); font-weight: 500; margin: 0 0 0.5rem 0; }
	.post-list { list-style: none; }
	.post-item { padding: 0.6rem 0; display: grid; grid-template-columns: 7rem 1fr; gap: 0.75rem; align-items: baseline; }
	.post-item + .post-item { border-top: 1px solid var(--border); }
	.post-date { font-family: var(--font-mono); font-size: 0.8rem; color: var(--text-tertiary); white-space: nowrap; }
	.post-link { font-weight: 500; font-size: 0.95rem; text-decoration: none; line-height: 1.4; }
	.post-link:hover { text-decoration: underline; text-decoration-color: currentColor; }
	.post-tags { display: inline-flex; gap: 0.35rem; margin-top: 0.25rem; flex-wrap: wrap; }
	.post-tag { font-family: var(--font-mono); font-size: 0.7rem; color: var(--tag-text); background: var(--tag-bg); padding: 0.1em 0.5em; border-radius: 3px; }
	@media (max-width: 640px) { .post-item { grid-template-columns: 1fr; } }
</style>
